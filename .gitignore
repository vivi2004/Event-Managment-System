build/
dist/
.next/
.nuxt/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Temporary files
tmp/
temp/

# Railway/Render config (sensitive)
railway.yml

# Local development
.vscode-test
